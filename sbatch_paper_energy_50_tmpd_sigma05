#!/bin/bash
#SBATCH --partition main
#SBATCH --qos normal
#SBATCH --time 7-00:00:00
#SBATCH --job-name ltmpd_s05
#SBATCH --output train-%J.out
#SBATCH --gpus=1

echo `date`
echo -e "\nSLURM_JOBID:\t\t" $SLURM_JOBID
echo -e "SLURM_JOB_NODELIST:\t" $SLURM_JOB_NODELIST "\n\n"

cd "${SLURM_SUBMIT_DIR}" || { echo "cd SLURM_SUBMIT_DIR failed"; exit 1; }
export PYTHONUNBUFFERED=1

### L-TMPD sigma_y sweep #2 (strong regularization).  Target: break the
### memorization -> divergence feedback loop observed at sigma_y_ratio=0.1.
module load anaconda
source activate idan2_env
python run_co_evolving_em.py \
    --config ./configs/seq_len_24/energy.yaml \
    --missing_rate 0.5 \
    --allow_tf32 \
    --wandb true \
    --tags "delay" "energy" "50_missing_rate" "ltmpd" "sigma_sweep" "sigma05" \
    --e_step_sampler tmpd \
    --adaptive_sigma_y \
    --sigma_y_ratio 0.5 \
    --sigma_y_floor 0.10 \
    --mmps_cg_iters 5 \
    --consistency_projection \
    --obs_space_cg \
    --warm_start_cg \
    --lambda_obs 0.0 \
    --lambda_rep 0.0 \
    --no_phase3
