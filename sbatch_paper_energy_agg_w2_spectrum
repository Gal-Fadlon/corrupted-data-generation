#!/bin/bash
#SBATCH --partition main
#SBATCH --qos normal
#SBATCH --time 7-00:00:00
#SBATCH --job-name paper_energy_agg_w2_spectrum
#SBATCH --output train-%J.out
#SBATCH --gpus=1

echo `date`
echo -e "\nSLURM_JOBID:\t\t" $SLURM_JOBID
echo -e "SLURM_JOB_NODELIST:\t" $SLURM_JOB_NODELIST "\n\n"

cd "${SLURM_SUBMIT_DIR}" || { echo "cd SLURM_SUBMIT_DIR failed"; exit 1; }
export PYTHONUNBUFFERED=1

### Operator-generality axis: temporal block-mean aggregation, w=2, Energy.
### Variant: empirical-spectrum-matched null-space noise.
###
### Motivation (post-cerulean-disco-2325):
###   The iid variant's white spectrum (and the smooth variant's generic
###   low-pass) are both only approximations of the real Energy PSD.  This
###   variant estimates the per-channel mean power spectral density of the
###   clean training set and synthesizes null-space noise with that exact
###   amplitude spectrum and random phases via rFFT/iFFT.  The synthesized
###   noise is per-window centered to preserve A x = y exactly.
###
### This is the most principled of the three variants: it matches the 2nd-
### order statistics of the target distribution directly, so the M-step
### sees within-window fine structure whose PSD is indistinguishable from
### the real data.  It does NOT match higher-order statistics (non-
### Gaussianity, phase coupling), which is why we still expect some
### residual disc_mean gap due to the structural null-space of block-mean.
###
### All other settings identical to the paper-proven aggregate_w2 run.
module load anaconda
source activate idan2_env
python run_co_evolving_em_aggregate.py \
    --config ./configs/seq_len_24/energy.yaml \
    --corruption_type aggregate \
    --agg_window 2 \
    --agg_noise_model spectrum \
    --agg_noise_sigma 0.1 \
    --missing_rate 0.0 \
    --wandb true \
    --tags "paper" "energy" "aggregate_w2" "spectrum_noise" "co_evolving_em" \
    --adaptive_sigma_y \
    --sigma_y_ratio 0.1 \
    --sigma_y_floor 0.01 \
    --mmps_cg_iters 5 \
    --consistency_projection \
    --obs_space_cg \
    --no_warm_start_cg \
    --lambda_obs 0 \
    --lambda_rep 0 \
    --em_iters 5 \
    --phase3 \
    --eval_all_metrics
