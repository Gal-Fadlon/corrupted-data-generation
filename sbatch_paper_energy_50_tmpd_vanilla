#!/bin/bash
#SBATCH --partition main
#SBATCH --qos normal
#SBATCH --time 7-00:00:00
#SBATCH --job-name tmpd_van
#SBATCH --output train-%J.out
#SBATCH --gpus=1

echo `date`
echo -e "\nSLURM_JOBID:\t\t" $SLURM_JOBID
echo -e "SLURM_JOB_NODELIST:\t" $SLURM_JOB_NODELIST "\n\n"

cd "${SLURM_SUBMIT_DIR}" || { echo "cd SLURM_SUBMIT_DIR failed"; exit 1; }
export PYTHONUNBUFFERED=1

### Vanilla TMPD ablation on delay embedding: TMPD applied directly in image
### space.  Intentionally violates PSLR's C1 (composed G) and C3 (manifold
### projection) while keeping TMPD's native C2 (row-sum diagonal).
###
### Differences from sbatch_paper_energy_50_tmpd (L-TMPD):
###   +  --e_step_sampler tmpd_vanilla   (forces image-space TMPD path)
###   +  --no_consistency_projection     (C3 violation -- no manifold proj.)
###   +  --no_obs_space_cg               (explicit C1 violation signal)
###   -  --warm_start_cg REMOVED         (no CG to warm-start)
###
### Expected: underperforms L-TMPD and L-MMPS by the same mechanism that naive
### image-space MMPS underperforms L-MMPS -- operator mismatch biases the
### posterior mean.
module load anaconda
source activate idan2_env
python run_co_evolving_em.py \
    --config ./configs/seq_len_24/energy.yaml \
    --missing_rate 0.5 \
    --allow_tf32 \
    --wandb true \
    --tags "delay" "energy" "50_missing_rate" "tmpd_vanilla" "ablation" \
    --e_step_sampler tmpd_vanilla \
    --adaptive_sigma_y \
    --sigma_y_ratio 0.1 \
    --sigma_y_floor 0.01 \
    --mmps_cg_iters 5 \
    --no_consistency_projection \
    --no_obs_space_cg \
    --lambda_obs 0.0 \
    --lambda_rep 0.0 \
    --no_phase3
