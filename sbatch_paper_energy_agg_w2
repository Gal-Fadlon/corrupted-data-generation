#!/bin/bash
#SBATCH --partition rtx6000
#SBATCH --qos azencot
#SBATCH --time 7-00:00:00
#SBATCH --job-name paper_energy_agg_w2
#SBATCH --output train-%J.out
#SBATCH --gpus=1

echo `date`
echo -e "\nSLURM_JOBID:\t\t" $SLURM_JOBID
echo -e "SLURM_JOB_NODELIST:\t" $SLURM_JOB_NODELIST "\n\n"

cd "${SLURM_SUBMIT_DIR}" || { echo "cd SLURM_SUBMIT_DIR failed"; exit 1; }
export PYTHONUNBUFFERED=1

### Operator-generality axis: temporal block-mean aggregation, w=2, on Energy.
### Our co-evolving EM method with the full five corrections the paper
### identifies for the dual-space setting:
###   - Observation-space CG (Prop 4) in R^{N_obs x F} with exact A_ts adjoint.
###   - Adaptive sigma_y = c * sigma_t (Prop 2).
###   - Manifold projection + Moore-Penrose observation enforcement (Prop 1).
###   - Warm-started CG across reverse steps (Section 5.7) -- disabled here
###     to match the proven sbatch_paper_energy_70 configuration.
### missing_rate is 0 (aggregation is the sole corruption under test).
### L_obs / L_rep are off (same setting that wins on 50%-missing Energy).
module load anaconda
source activate idan2_env
python run_co_evolving_em_aggregate.py \
    --config ./configs/seq_len_24/energy.yaml \
    --corruption_type aggregate \
    --agg_window 2 \
    --missing_rate 0.0 \
    --wandb true \
    --tags "paper" "energy" "aggregate_w2" "co_evolving_em" \
    --adaptive_sigma_y \
    --sigma_y_ratio 0.1 \
    --sigma_y_floor 0.01 \
    --mmps_cg_iters 5 \
    --consistency_projection \
    --obs_space_cg \
    --no_warm_start_cg \
    --lambda_obs 0 \
    --lambda_rep 0 \
    --em_iters 5 \
    --phase3 \
    --eval_all_metrics
