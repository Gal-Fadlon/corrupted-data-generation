#!/bin/bash
#SBATCH --partition main
#SBATCH --qos normal
#SBATCH --time 3-00:00:00
#SBATCH --job-name stft_e768_b
#SBATCH --output stft_e768_b-%J.out
#SBATCH --gpus=1
#SBATCH --mem=64G
#SBATCH --cpus-per-task=8

echo `date`
echo -e "\nSLURM_JOBID:\t\t" $SLURM_JOBID
echo -e "SLURM_JOB_NODELIST:\t" $SLURM_JOB_NODELIST "\n\n"

cd "${SLURM_SUBMIT_DIR}" || { echo "cd SLURM_SUBMIT_DIR failed"; exit 1; }
export PYTHONUNBUFFERED=1

### STFT lift at seq_len=768, Energy, 50% missing
### Regime (b): wrong CG space (image-space mask), other corrections ON
### adaptive sigma_y + proj + warm-start CG all ON, obs-space CG explicitly OFF
module load anaconda
source activate idan2_env
python run_co_evolving_em.py \
    --config ./configs/seq_len_768/energy.yaml \
    --missing_rate 0.5 \
    --allow_tf32 \
    --embedder stft \
    --wandb true \
    --tags "stft_validation" "energy" "seq_len_768" "50_missing_rate" "img_space_cg" "regime_b" \
    --adaptive_sigma_y \
    --sigma_y_ratio 0.1 \
    --sigma_y_floor 0.01 \
    --mmps_cg_iters 5 \
    --consistency_projection \
    --no_obs_space_cg \
    --warm_start_cg \
    --lambda_obs 0.0 \
    --lambda_rep 0.0 \
    --stft_n_fft 63 \
    --stft_hop_length 25 \
    --stft_scale_mode zscore \
    --stft_pad_mode reflect \
    --em_iters 10 \
    --m_step_epochs 30 \
    --init_method linear \
    --no_phase3
