#!/bin/bash
#SBATCH --partition rtx6000
#SBATCH --qos azencot
#SBATCH --time 7-00:00:00
#SBATCH --job-name paper_pigdm_em
#SBATCH --output train-%J.out
#SBATCH --gpus=1

echo `date`
echo -e "\nSLURM_JOBID:\t\t" $SLURM_JOBID
echo -e "SLURM_JOB_NODELIST:\t" $SLURM_JOB_NODELIST "\n\n"

cd "${SLURM_SUBMIT_DIR}" || { echo "cd SLURM_SUBMIT_DIR failed"; exit 1; }
export PYTHONUNBUFFERED=1

### Table 3 Row 1c: PiGDM-EM on Energy 50%
module load anaconda
source activate idan2_env
python run_diffem_pigdm.py \
    --config ./configs/seq_len_24/energy.yaml \
    --missing_rate 0.5 \
    --wandb true \
    --tags "paper" "energy" "50_missing_rate" "pigdm_em" "table3_row1c" \
    --pigdm_sigma_y 0.01 \
    --em_iters 5 \
    --eval_all_metrics
