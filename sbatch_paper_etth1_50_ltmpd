#!/bin/bash
#SBATCH --partition rtx6000
#SBATCH --qos azencot
#SBATCH --time 7-00:00:00
#SBATCH --job-name ltmpd_eh1
#SBATCH --output train-%J.out
#SBATCH --gpus=1

echo `date`
echo -e "\nSLURM_JOBID:\t\t" $SLURM_JOBID
echo -e "SLURM_JOB_NODELIST:\t" $SLURM_JOB_NODELIST "\n\n"

cd "${SLURM_SUBMIT_DIR}" || { echo "cd SLURM_SUBMIT_DIR failed"; exit 1; }
export PYTHONUNBUFFERED=1

### L-TMPD (PSLR applied to TMPD) on ETTh1 50% missing -- dataset generalization
### check for the Energy sigma-sweep winner (sigma_y_ratio=0.3, sigma_y_floor=0.05).
### Full four-correction PSLR stack: obs-space residual with composed G,
### adaptive sigma_y, manifold projection with hard obs enforcement, and
### STL warm start.  Expected outcome: disc_mean competitive with L-MMPS on
### ETTh1, supporting the "PSLR recipe is sampler-agnostic" claim.
module load anaconda
source activate idan2_env
python run_co_evolving_em.py \
    --config ./configs/seq_len_24/etth1.yaml \
    --missing_rate 0.5 \
    --allow_tf32 \
    --wandb true \
    --tags "delay" "etth1" "50_missing_rate" "ltmpd" "dataset_generalization" \
    --e_step_sampler tmpd \
    --adaptive_sigma_y \
    --sigma_y_ratio 0.3 \
    --sigma_y_floor 0.05 \
    --mmps_cg_iters 5 \
    --consistency_projection \
    --obs_space_cg \
    --warm_start_cg \
    --lambda_obs 0.0 \
    --lambda_rep 0.0 \
    --no_phase3
