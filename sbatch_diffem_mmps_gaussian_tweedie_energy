#!/bin/bash
################################################################################################
### DiffEM MMPS Gaussian Tweedie (Approach E): Ambient Tweedie + consistency loss.
### Fallback: main + normal.
################################################################################################

#SBATCH --time 7-00:00:00
#SBATCH --job-name gn_tweedie
#SBATCH --output diffem_gn_tweedie-%A_%a.out
#SBATCH --error diffem_gn_tweedie-%A_%a.out.err
#SBATCH --partition main
#SBATCH --qos normal
#SBATCH --mem=32G
#SBATCH --cpus-per-task=6
#SBATCH --gpus=rtx_3090:1
##SBATCH --gpus=rtx_4090:1
#SBATCH --array=0-4

cd "${SLURM_SUBMIT_DIR}" || { echo "cd SLURM_SUBMIT_DIR failed"; exit 1; }
export PYTHONUNBUFFERED=1

SIGMAS=(0.03 0.06 0.09 0.12 0.18)
SIG=${SIGMAS[$SLURM_ARRAY_TASK_ID]}

echo "$(date)  array_task=${SLURM_ARRAY_TASK_ID}  sigma=${SIG}"

module load anaconda
source activate /home/arbivid/.conda/envs/idan2_env

python run_diffem_mmps_gaussian_tweedie.py \
    --config ./configs/seq_len_24/energy.yaml \
    --corruption_noise_level "${SIG}" \
    --allow_tf32 \
    --wandb true \
    --use_ambient_tweedie_mstep \
    --ambient_tweedie_loss_weight 0.1 \
    --ambient_tweedie_consistency_weight 0.05 \
    --tags "diffem_mmps_gaussian_tweedie" "energy" "sigma${SIG}" "ambient_dsm" "consistency" "tf32"
