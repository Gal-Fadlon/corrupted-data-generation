#!/bin/bash

################################################################################################
### Ambient-MMPS Gaussian aligned (σ grid). main/normal + generic 1 GPU — no_golden template.
### Submit when rtx6000 array tasks stay PD (MaxGRESPerAccount).
################################################################################################

#SBATCH --partition main
#SBATCH --qos normal
##SBATCH --gpus=rtx_3090:1
##SBATCH --gpus=rtx_4090:1
#SBATCH --time 7-00:00:00
#SBATCH --job-name amb_gnoise_ng
#SBATCH --output amb_gnoise_ng-%A_%a.out
#SBATCH --gpus=1
#SBATCH --array=0-4
#SBATCH --mem=32G
#SBATCH --cpus-per-task=6

cd "${SLURM_SUBMIT_DIR}" || { echo "cd SLURM_SUBMIT_DIR failed"; exit 1; }
export PYTHONUNBUFFERED=1
# Reduce allocator fragmentation OOMs on long MMPS / phase-0 runs
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

SIGMAS=(0.03 0.06 0.09 0.12 0.18)
SIG=${SIGMAS[$SLURM_ARRAY_TASK_ID]}

echo "$(date)  array_task=${SLURM_ARRAY_TASK_ID}  sigma=${SIG}"

module load anaconda
source activate /home/arbivid/.conda/envs/idan2_env

python run_diffem_ambient_mmps.py \
  --config ./configs/seq_len_24/energy.yaml \
  --missing_rate 0 \
  --corruption_type gaussian_noise \
  --corruption_noise_level "${SIG}" \
  --wandb true \
  --tags "ambient_mmps" "gaussian_aligned" "energy" "sigma${SIG}" "seq_len_24" "vs_irregular_baseline" "no_golden" "main_gpus1"
