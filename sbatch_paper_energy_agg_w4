#!/bin/bash
#SBATCH --partition rtx6000
#SBATCH --qos azencot
#SBATCH --time 7-00:00:00
#SBATCH --job-name paper_energy_agg_w4
#SBATCH --output train-%J.out
#SBATCH --gpus=1

echo `date`
echo -e "\nSLURM_JOBID:\t\t" $SLURM_JOBID
echo -e "SLURM_JOB_NODELIST:\t" $SLURM_JOB_NODELIST "\n\n"

cd "${SLURM_SUBMIT_DIR}" || { echo "cd SLURM_SUBMIT_DIR failed"; exit 1; }
export PYTHONUNBUFFERED=1

### Operator-generality axis: temporal block-mean aggregation, w=4, on Energy.
### Identical configuration to sbatch_paper_energy_agg_w2 except agg_window=4
### (N_obs per sample drops from 12 to 6 -- the harder of the two regimes).
module load anaconda
source activate idan2_env
python run_co_evolving_em_aggregate.py \
    --config ./configs/seq_len_24/energy.yaml \
    --corruption_type aggregate \
    --agg_window 4 \
    --missing_rate 0.0 \
    --wandb true \
    --tags "paper" "energy" "aggregate_w4" "co_evolving_em" \
    --adaptive_sigma_y \
    --sigma_y_ratio 0.1 \
    --sigma_y_floor 0.01 \
    --mmps_cg_iters 5 \
    --consistency_projection \
    --obs_space_cg \
    --no_warm_start_cg \
    --lambda_obs 0 \
    --lambda_rep 0 \
    --em_iters 5 \
    --phase3 \
    --eval_all_metrics
