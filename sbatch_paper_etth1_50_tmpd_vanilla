#!/bin/bash
#SBATCH --partition rtx6000
#SBATCH --qos azencot
#SBATCH --time 7-00:00:00
#SBATCH --job-name tmpdv_eh1
#SBATCH --output train-%J.out
#SBATCH --gpus=1

echo `date`
echo -e "\nSLURM_JOBID:\t\t" $SLURM_JOBID
echo -e "SLURM_JOB_NODELIST:\t" $SLURM_JOB_NODELIST "\n\n"

cd "${SLURM_SUBMIT_DIR}" || { echo "cd SLURM_SUBMIT_DIR failed"; exit 1; }
export PYTHONUNBUFFERED=1

### Vanilla TMPD ablation on ETTh1 50% missing -- companion to the L-TMPD run.
### Uses image-space mask A_img instead of composed G (violates C1), no
### manifold projection (violates C3); adaptive sigma_y kept so the baseline
### is as strong as possible.  Expected outcome: disc_mean >> L-TMPD, showing
### that without PSLR corrections TMPD lands in regime (b)/(c) of Theorem 4.1
### on ETTh1 as well as on Energy.
module load anaconda
source activate idan2_env
python run_co_evolving_em.py \
    --config ./configs/seq_len_24/etth1.yaml \
    --missing_rate 0.5 \
    --allow_tf32 \
    --wandb true \
    --tags "delay" "etth1" "50_missing_rate" "tmpd_vanilla" "ablation" "dataset_generalization" \
    --e_step_sampler tmpd_vanilla \
    --adaptive_sigma_y \
    --sigma_y_ratio 0.1 \
    --sigma_y_floor 0.01 \
    --mmps_cg_iters 5 \
    --no_consistency_projection \
    --no_obs_space_cg \
    --lambda_obs 0.0 \
    --lambda_rep 0.0 \
    --no_phase3
