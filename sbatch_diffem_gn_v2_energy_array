#!/bin/bash
################################################################################################
### DiffEM MMPS Gaussian noise V2 — 7 fixes (64 E-step steps, CG=3, 200 warmstart,
### Phase 3 continues from EM model, EM early stopping, TF32 enabled).
### Sigma grid: 0.03, 0.06, 0.09.  Partition: main + normal + RTX 3090.
################################################################################################

#SBATCH --time 7-00:00:00
#SBATCH --job-name diffem_gn_v2
#SBATCH --output diffem_gn_v2-%A_%a.out
#SBATCH --error diffem_gn_v2-%A_%a.out.err
#SBATCH --partition main
#SBATCH --qos normal
#SBATCH --mem=32G
#SBATCH --cpus-per-task=6
#SBATCH --gpus=rtx_3090:1
##SBATCH --gpus=rtx_4090:1
#SBATCH --array=0-2

cd "${SLURM_SUBMIT_DIR}" || { echo "cd SLURM_SUBMIT_DIR failed"; exit 1; }
export PYTHONUNBUFFERED=1

SIGMAS=(0.03 0.06 0.09)
SIG=${SIGMAS[$SLURM_ARRAY_TASK_ID]}

echo "$(date)  array_task=${SLURM_ARRAY_TASK_ID}  sigma=${SIG}"

module load anaconda
source activate /home/arbivid/.conda/envs/idan2_env

python run_diffem_mmps_gaussian_noise_v2.py \
  --config ./configs/seq_len_24/energy.yaml \
  --corruption_noise_level "${SIG}" \
  --mmps_cg_iters 3 \
  --allow_tf32 \
  --wandb true \
  --tags "diffem_mmps_gaussian_noise_v2" "energy" "sigma${SIG}" "seq_len_24" "vs_irregular_baseline" "main_normal" "64steps_cg3" "warmstart200" "tf32"
